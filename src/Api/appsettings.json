{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.Seq" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext} {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ],
    "Properties": {
      "Application": "ClientPortal.Api"
    }
  },
  "ConnectionStrings": {
    "Postgres": "",
    "Redis": ""
  },
  "HealthChecks": {
    "S3": {
      "Region": "",
      "BucketName": ""
    }
  },
  "Jwt": {
    "Issuer": "client-portal",
    "Audience": "client-portal-api",
    "PrivateKeyPem": "-----BEGIN PRIVATE KEY-----\\nREPLACE_WITH_BASE64_DER_PRIVATE_KEY\\n-----END PRIVATE KEY-----",
    "PublicKeyPem": "-----BEGIN PUBLIC KEY-----\\nREPLACE_WITH_BASE64_DER_PUBLIC_KEY\\n-----END PUBLIC KEY-----",
    "AccessTokenLifetimeMinutes": 15
  },
  "RefreshToken": {
    "TokenSizeBytes": 32,
    "LifetimeDays": 7,
    "Iterations": 4,
    "MemorySizeKb": 65536,
    "DegreeOfParallelism": 2,
    "Pepper": "replace-with-strong-refresh-token-pepper"
  },
  "RefreshTokenCookie": {
    "Name": "refreshToken",
    "ExpiryDays": 7
  },
  "Cors": {
    "TenantAllowedOrigins": []
  },
  "Notifications": {
    "Email": {
      "Enabled": false,
      "SmtpHost": "",
      "SmtpPort": 587,
      "UseSsl": true,
      "Username": "",
      "Password": "",
      "FromAddress": "noreply@clientportal.local",
      "FromName": "ClientPortal"
    },
    "WhatsApp": {
      "Enabled": false,
      "BaseUrl": "https://api.twilio.com",
      "AccountSid": "",
      "AuthToken": "",
      "FromNumber": ""
    }
  },
  "AllowedHosts": "*"
}
