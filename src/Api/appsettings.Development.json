{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug"
    }
  },
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5433;Database=client_portal;Username=postgres;Password=postgres",
    "Redis": "localhost:6379"
  },
  "HealthChecks": {
    "S3": {
      "Enabled": false,
      "Region": "",
      "BucketName": ""
    }
  },
  "Cors": {
    "DevelopmentOrigins": [
      "http://localhost:4200",
      "https://localhost:4200",
      "http://127.0.0.1:4200",
      "https://127.0.0.1:4200"
    ]
  },
  "Tenancy": {
    "TenantKey": {
      "Enabled": true,
      "HeaderName": "X-Tenant-Key",
      "Pepper": "development-only-set-user-secrets-for-production"
    }
  }
}
